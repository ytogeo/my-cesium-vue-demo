# Copy this file to .env and fill in your own API tokens.
# .env must NOT be committed to version control.

# Cesium Ion access token — get yours at https://cesium.com/ion/tokens
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Mapbox credentials — get yours at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_USERNAME=your_mapbox_username_here
VITE_MAPBOX_STYLE_ID=your_mapbox_style_id_here
VITE_MAPBOX_TOKEN=your_mapbox_access_token_here

# Tianditu (天地图) token — get yours at https://console.tianditu.gov.cn/
VITE_TIANDITU_TOKEN=your_tianditu_token_here
